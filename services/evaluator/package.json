{
  "name": "@denki/evaluator",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx source/main.ts",
    "format": "prettier --config ../../configuration/.prettierrc --write .",
    "format:check": "prettier --config ../../configuration/.prettierrc --check .",
    "start": "node build/main.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "watch": "tsx watch source/main.ts"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.2",
    "@mastra/core": "^1.34.0",
    "@supabase/supabase-js": "^2.105.4",
    "hono": "^4.12.18",
    "inngest": "^4.4.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "prettier": "^3.8.3",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
