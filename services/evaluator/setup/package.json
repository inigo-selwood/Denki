{
  "name": "@denki/evaluator",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p ../configuration/tsconfig.json && node -e \"require('node:fs').writeFileSync('../build/package.json', '{\\\"type\\\":\\\"module\\\"}\\n')\"",
    "db:push": "drizzle-kit push --config ../configuration/drizzle.config.ts --force",
    "dev": "tsx ../source/main.ts",
    "format": "prettier --config ../../../configuration/.prettierrc --write ../source ../test ../configuration package.json",
    "format:check": "prettier --config ../../../configuration/.prettierrc --check ../source ../test ../configuration package.json",
    "start": "node ../build/main.js",
    "test": "vitest run --root ..",
    "test:watch": "vitest --root ..",
    "typecheck": "tsc -p ../configuration/tsconfig.typecheck.json --noEmit",
    "watch": "tsx watch ../source/main.ts"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.2",
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "^1.4.0",
    "@mastra/core": "^1.34.0",
    "@supabase/supabase-js": "^2.105.4",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.18",
    "inngest": "^4.4.0",
    "postgres": "^3.4.9",
    "reductoai": "^0.15.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "drizzle-kit": "^0.31.10",
    "prettier": "^3.8.3",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
